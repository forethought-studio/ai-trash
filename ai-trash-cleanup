#!/bin/bash
# ai-trash-cleanup – purge ai-trash entries older than 30 days

PLATFORM=$(uname -s)

if [[ "$PLATFORM" == "Darwin" ]]; then
  # Purge xattr-tagged items in ~/.Trash/ older than 30 days
  while IFS= read -r -d '' item; do
    xattr -p com.ai-trash.original-path "$item" >/dev/null 2>&1 && /bin/rm -rf "$item"
  done < <(find "$HOME/.Trash" -maxdepth 1 -mindepth 1 -mtime +30 -print0 2>/dev/null)
else
  # Linux: purge items in ~/.local/share/Trash/ai-trash/ older than 30 days
  AI_TRASH="$HOME/.local/share/Trash/ai-trash"
  [[ -d "$AI_TRASH" ]] || exit 0
  find "$AI_TRASH" -maxdepth 1 -mindepth 1 -mtime +30 -exec /bin/rm -rf {} \;
fi
